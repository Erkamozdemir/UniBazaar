<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="20" styleClass="auth-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unibazaar.controllers.AddListingController">
    <padding><Insets bottom="20" left="40" right="40" top="20" /></padding>
    
    <HBox alignment="CENTER_LEFT" prefWidth="600">
        <Button text="← Go Back" onAction="#onGoBackClicked" styleClass="filter-button" style="-fx-background-color: transparent; -fx-text-fill: #7BC8A4; -fx-padding: 0;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox alignment="CENTER" spacing="10" styleClass="auth-box" maxWidth="600">
        <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>
        <Label styleClass="app-title" text="Add Listing" />
        <Label styleClass="auth-subtitle" text="Create a new listing for your product" />
        
        <Label fx:id="statusLabel" styleClass="status-label" />
        
        <HBox spacing="10" alignment="CENTER">
            <VBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label text="Title (Required)" styleClass="auth-label"/>
                <TextField fx:id="titleField" promptText="e.g. Calculus Textbook" styleClass="auth-field"/>
            </VBox>
            <VBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label text="Original Price (₺)" styleClass="auth-label"/>
                <TextField fx:id="priceField" promptText="e.g. 150" styleClass="auth-field"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <VBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label text="Category" styleClass="auth-label"/>
                <ComboBox fx:id="categoryComboBox" promptText="Select Category" styleClass="auth-field" prefWidth="250" />
            </VBox>
            <VBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label text="Brand (Optional)" styleClass="auth-label"/>
                <TextField fx:id="brandField" promptText="e.g. Pearson" styleClass="auth-field"/>
            </VBox>
        </HBox>

        <VBox spacing="5" alignment="CENTER_LEFT" prefWidth="600">
            <Label text="Course Code (Optional)" styleClass="auth-label"/>
            <TextField fx:id="courseCodeField" promptText="e.g. MATH101" styleClass="auth-field"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER_LEFT" prefWidth="600">
            <Label text="Description" styleClass="auth-label"/>
            <TextArea fx:id="descriptionField" promptText="Describe your product..." prefRowCount="3" styleClass="auth-field"/>
        </VBox>
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Select Image" onAction="#onSelectImageClicked" styleClass="filter-button" />
            <Label fx:id="imagePathLabel" styleClass="auth-subtitle" text="No image selected" />
        </HBox>
        <ImageView fx:id="previewImage" fitHeight="120" fitWidth="160" preserveRatio="true" />
        
        <Button fx:id="saveButton" onAction="#onSaveClicked" styleClass="auth-button" text="Publish Listing" prefWidth="300" />
    </VBox>
</VBox>
