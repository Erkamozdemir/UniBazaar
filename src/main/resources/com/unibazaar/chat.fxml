<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unibazaar.controllers.ChatController" styleClass="dashboard-root">
    
    <left>
        <VBox spacing="10" styleClass="auth-box" prefWidth="250">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Button text="← Back" onAction="#onBackClicked" styleClass="auth-button"/>
            <Label text="My Chats" styleClass="app-subtitle"/>
            <ListView fx:id="chatsList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="auth-box">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label fx:id="chatTitleLabel" text="Select a chat" styleClass="card-title"/>
                <Label fx:id="statusLabel" text="" styleClass="status-label"/>
            </HBox>

            <HBox fx:id="ratingBox" spacing="10" alignment="CENTER_LEFT" styleClass="auth-box" visible="false" managed="false">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Rate Seller:" styleClass="card-title"/>
                <javafx.scene.control.ComboBox fx:id="ratingComboBox"/>
                <Button text="Submit Rating" onAction="#onSubmitRating" styleClass="filter-button"/>
            </HBox>

            <HBox fx:id="transactionBox" spacing="10" alignment="CENTER_LEFT" styleClass="auth-box" visible="false" managed="false">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label fx:id="transactionStatusLabel" text="Pending Transaction" styleClass="card-title"/>
                <Button fx:id="confirmSaleButton" text="Confirm Sale" onAction="#onConfirmSale" styleClass="auth-button"/>
                <Button text="Cancel" onAction="#onCancelTransaction" styleClass="auth-button" style="-fx-background-color: #B53F45;"/>
            </HBox>

            <ScrollPane fx:id="messagesScroll" VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="scroll-pane">
                <VBox fx:id="messagesContainer" spacing="10" styleClass="dashboard-root">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                </VBox>
            </ScrollPane>

            <HBox spacing="10" alignment="CENTER">
                <TextArea fx:id="messageInput" promptText="Type a message..." HBox.hgrow="ALWAYS" prefHeight="50" wrapText="true" style="-fx-font-size: 14px;"/>
                <Button text="Send" onAction="#onSendClicked" styleClass="auth-button" prefHeight="50"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
