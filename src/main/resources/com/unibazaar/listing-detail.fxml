<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unibazaar.controllers.ListingDetailController" styleClass="dashboard-root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="dashboard-header">
            <padding><Insets bottom="20" left="32" right="32" top="20" /></padding>
            <Button text="← Back" onAction="#onBackClicked" styleClass="auth-button"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="app-title" text="Listing Details" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox spacing="32" alignment="TOP_CENTER">
                <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                
                <VBox alignment="TOP_CENTER" spacing="10">
                    <ImageView fx:id="listingImage" fitWidth="400" fitHeight="400" preserveRatio="true" styleClass="detail-image"/>
                    <Label fx:id="campaignBadge" styleClass="campaign-badge" visible="false"/>
                </VBox>

                
                <VBox spacing="16" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="500">
                    <Label fx:id="titleLabel" styleClass="detail-title" wrapText="true"/>
                    <Label fx:id="courseCodeLabel" styleClass="detail-course"/>
                    
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="price-section">
                        <Label fx:id="originalPriceLabel" styleClass="detail-original-price"/>
                        <Label fx:id="discountPriceLabel" styleClass="detail-discount-price"/>
                    </HBox>

                    <VBox spacing="4" style="-fx-background-color: #132A22; -fx-padding: 16; -fx-background-radius: 8;">
                        <Label fx:id="sellerLabel" styleClass="detail-seller"/>
                        <Label fx:id="ratingLabel" styleClass="welcome-info" text="Seller Rating: ⭐ 0.0 (0 reviews)"/>
                        <Label fx:id="conditionLabel" styleClass="welcome-info" text="Condition: Used"/>
                        <Label fx:id="locationLabel" styleClass="welcome-info" text="Location: Campus"/>
                    </VBox>

                    <Label text="Description:" styleClass="welcome-title"/>
                    <Label fx:id="descriptionLabel" styleClass="detail-description" wrapText="true"/>
                    
                    <Region VBox.vgrow="ALWAYS" minHeight="20"/>

                    <HBox spacing="10">
                        <Button fx:id="purchaseButton" text="Purchase Now" onAction="#onPurchaseClicked" styleClass="purchase-button"/>
                        <Button fx:id="offerButton" text="Make Offer" onAction="#onMakeOfferClicked" styleClass="filter-button" prefHeight="45"/>
                        <Button text="Message Seller" onAction="#onMessageSellerClicked" styleClass="auth-button" style="-fx-background-color: #5BA885;"/>
                    </HBox>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
