<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboard-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unibazaar.controllers.SellerDashboardController">

    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="dashboard-header">
            <padding><Insets bottom="20" left="32" right="32" top="20" /></padding>
            <VBox>
                <Label styleClass="app-title" text="UniBazaar" />
                <Label fx:id="sellerNameLabel" styleClass="app-subtitle" text="Welcome, Seller" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addListingBtn" text="+ Add Listing" styleClass="auth-button" onAction="#onAddListingClicked" />
        </HBox>
    </top>

    
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="10">
                <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>
                <Label text="My Listings" styleClass="section-title" />
                <Label fx:id="statusLabel" styleClass="status-label" />
                <FlowPane fx:id="listingsGrid" hgap="16" vgap="16" styleClass="listings-grid">
                    
                </FlowPane>
            </VBox>
        </ScrollPane>
    </center>

    
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #0F221A; -fx-border-color: #1E3D32 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
            <padding><Insets bottom="16" left="32" right="32" top="16" /></padding>
            <?import javafx.scene.control.MenuButton?>
            <?import javafx.scene.control.MenuItem?>
            <MenuButton text="Settings" styleClass="filter-button">
                <items>
                    <MenuItem text="Logout" onAction="#onLogoutClicked" />
                    <MenuItem text="Close Account" onAction="#onCloseAccountClicked" />
                </items>
            </MenuButton>
        </HBox>
    </bottom>

</BorderPane>
