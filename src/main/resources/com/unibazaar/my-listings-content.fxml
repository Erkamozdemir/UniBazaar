<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21">
    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="My Listings" styleClass="section-title"/>
        <Button text="+ Add Listing" onAction="#onAddListingClicked" styleClass="add-button"/>
    </HBox>

    <Label fx:id="statusLabel" styleClass="status-label"/>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="myListingsGrid" alignment="TOP_LEFT" hgap="16" vgap="16">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
        </FlowPane>
    </ScrollPane>
</VBox>
